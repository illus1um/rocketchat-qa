{
  "info": {
    "name": "Rocket.Chat QA Tests",
    "description": "API test collection for Rocket.Chat - Advanced QA Assignment 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "admin_user",
      "value": "admin"
    },
    {
      "key": "admin_pass",
      "value": "admin123"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "channel_id",
      "value": ""
    },
    {
      "key": "message_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has authToken', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('authToken');",
                  "    pm.expect(jsonData.data).to.have.property('userId');",
                  "    pm.collectionVariables.set('auth_token', jsonData.data.authToken);",
                  "    pm.collectionVariables.set('user_id', jsonData.data.userId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"user\": \"{{admin_user}}\", \"password\": \"{{admin_pass}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Login - Invalid Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Response indicates error', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal('error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"user\": \"admin\", \"password\": \"wrongpassword\"}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains username', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('username');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Auth-Token", "value": "{{auth_token}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            }
          }
        }
      ]
    },
    {
      "name": "Channels",
      "item": [
        {
          "name": "Create Channel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Channel created successfully', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.channel).to.have.property('_id');",
                  "    pm.collectionVariables.set('channel_id', jsonData.channel._id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Auth-Token", "value": "{{auth_token}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"postman-test-channel\"}"
            },
            "url": {
              "raw": "{{base_url}}/channels.create",
              "host": ["{{base_url}}"],
              "path": ["channels.create"]
            }
          }
        },
        {
          "name": "List Channels",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns array of channels', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.channels).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Auth-Token", "value": "{{auth_token}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/channels.list",
              "host": ["{{base_url}}"],
              "path": ["channels.list"]
            }
          }
        },
        {
          "name": "Delete Channel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Channel deleted', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Auth-Token", "value": "{{auth_token}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"roomId\": \"{{channel_id}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/channels.delete",
              "host": ["{{base_url}}"],
              "path": ["channels.delete"]
            }
          }
        }
      ]
    },
    {
      "name": "Messaging",
      "item": [
        {
          "name": "Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Message sent successfully', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.message).to.have.property('_id');",
                  "    pm.collectionVariables.set('message_id', jsonData.message._id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Auth-Token", "value": "{{auth_token}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"message\": {\"rid\": \"{{channel_id}}\", \"msg\": \"Hello from Postman!\"}}"
            },
            "url": {
              "raw": "{{base_url}}/chat.sendMessage",
              "host": ["{{base_url}}"],
              "path": ["chat.sendMessage"]
            }
          }
        },
        {
          "name": "Get Channel History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns messages array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.messages).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Auth-Token", "value": "{{auth_token}}" },
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/channels.history?roomId={{channel_id}}",
              "host": ["{{base_url}}"],
              "path": ["channels.history"],
              "query": [
                { "key": "roomId", "value": "{{channel_id}}" }
              ]
            }
          }
        }
      ]
    }
  ]
}
