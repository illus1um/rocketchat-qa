{
  "name": "rocketchat-qa",
  "version": "3.0.0",
  "description": "Rocket.Chat QA — API integration tests with CI/CD pipeline",
  "scripts": {
    "test": "jest --config jest.config.js --verbose",
    "test:coverage": "jest --config jest.config.js --verbose --coverage",
    "test:ci": "jest --config jest.config.js --verbose --coverage --ci --forceExit"
  },
  "devDependencies": {
    "axios": "^1.6.7",
    "jest": "^29.7.0"
  },
  "keywords": [
    "qa",
    "testing",
    "rocket-chat",
    "api-testing",
    "jest"
  ],
  "license": "MIT"
}
